-include: \
    ${workspace}/cnf/fixedIndices/bnd_buildpath_Eclipse_Platform.bndrun

-buildpath: \
	${fea_org.eclipse.rcp_4.35.0.v20250228-0640},\
	org.eclipse.swtbot.swt.finder,\
	org.eclipse.swtbot.junit4_x,\
	${junit},\
	slf4j.api

Bundle-SymbolicName: example.rcp.app.ui.swtbot.tests;singleton:=true
Bundle-Version: 0.1.0.${tstamp;yyyyMMdd-HHmmss}

Test-Cases: example.rcp.app.ui.swtbot.tests.SamplePartSWTBotTest

Private-Package: example.rcp.app.ui.swtbot.tests

# org.eclipse.core.runtime is a split package: both org.eclipse.core.runtime and
# org.eclipse.equinox.common contribute classes to it (Platform vs IStatus/ILogListener).
# bnd detects two buildpath providers and auto-adds ;common=split to Import-Package.
# Per OSGi spec all Import-Package attributes must match the Export-Package — but
# Eclipse Platform bundles do NOT export with common=split → wiring fails at runtime
# → NoClassDefFoundError for Platform, IStatus, ILogListener.
#
# Fix: Require-Bundle wires directly to the bundle without attribute matching.
# Equinox buddy loading (Eclipse-BuddyPolicy: registered on equinox.common,
# Eclipse-RegisterBuddy on core.runtime) makes all split-package classes accessible
# through the single Require-Bundle wiring.
# !org.eclipse.core.runtime in Import-Package blocks the auto-generated split entry.
Require-Bundle: org.eclipse.core.runtime;bundle-version="[3.33.0,4.0.0)"

Import-Package: \
    !org.eclipse.core.runtime, \
    *
