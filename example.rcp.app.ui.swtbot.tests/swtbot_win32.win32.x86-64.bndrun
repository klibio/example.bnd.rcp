# SWTBot test launch for example.rcp.app.ui on Windows (win32.win32.x86-64)
#
# Based on: example.rcp.app.ui/app.ui_win32.win32.x86-64.bndrun
#
# HOW TO RUN from bndtools IDE:
#   1. Open this file in bndtools.
#   2. Click "Resolve" to resolve the SWTBot bundles from the "SWTBot P2" repository
#      (registered in cnf/ext/swtbot.bnd) and populate -runbundles below.
#   3. Right-click this file → Run As / Debug As → Bnd OSGi Test Launchers.
#      The application starts with its full product configuration and the
#      SWTBotJunit4ClassRunner executes SamplePartSWTBotTest in a background thread.
#
# HOW TO RUN from bnd CLI (Java 21 required):
#   java -jar biz.aQute.bnd-7.3.0.jar runtests example.rcp.app.ui.swtbot.tests/swtbot_win32.win32.x86-64.bndrun
#
# NOTE: Use "bnd runtests", NOT "bnd test" or "bnd run".
#   bnd test: only processes bnd.bnd files and project directories — it silently
#             skips .bndrun files and exits 0 with no tests run.
#   bnd run:  ignores -tester so biz.aQute.junit is never injected.
#   bnd runtests: passes the .bndrun directly to runTest(), which creates a Project
#             from the .bndrun file and calls ProjectTester.test() correctly.
# Test-Cases must also be declared in this .bndrun file (not only in bnd.bnd)
# because bnd runtests reads properties from this file directly.

-include: \
    ${workspace}/example.rcp.app.ui/app.ui_shared.bndrun,\
    ${workspace}/cnf/shared/win32.win32.x86-64.bndrun

# Use bnd's built-in JUnit tester to discover and run Test-Cases bundles.
# biz.aQute.junit is injected by the ProjectTester infrastructure; it is NOT
# listed in -runbundles so there is no version conflict with standalone org.junit.
-tester: biz.aQute.junit

# Test-Cases must be declared here (not only in bnd.bnd) because
# "bnd runtests" creates a Project directly from this file and calls
# getProperties().getProperty("Test-Cases") — if that returns null,
# the test exits immediately with EXIT:0 and zero tests executed.
Test-Cases: example.rcp.app.ui.swtbot.tests.SamplePartSWTBotTest

# osgi.clean=true: force Equinox to discard any persisted bundle state from a
#   previous run (stale state from the bndtools IDE run causes mis-wired singletons
#   when new bundles like biz.aQute.junit are added with different bundle IDs).
# launch.storage.dir: keep test state separate from the normal app run (_rt/cfg)
#   so IDE and CLI runs do not pollute each other.
# tester.separatethread=true: biz.aQute.junit starts its test runner on a background
#   thread instead of registering a Runnable{main.thread=true} service, leaving the
#   main thread free for the SWT event loop driven by bndtools.runtime.applaunch.eclipse4.
#   Without this, biz.aQute.junit and the E4 app compete for the main thread.
# tester.unresolved=false: skip the unresolved-bundle check that biz.aQute.junit runs
#   before tests (it can exit early with BndSystem.exit if any bundle is INSTALLED).
-runproperties.swtbot: \
	osgi.clean=true,\
	launch.storage.dir=_rt/swtbot_cfg,\
	tester.separatethread=true,\
	tester.unresolved=false

# Win32-specific RCP feature requirement (same as the base bndrun)
-runrequires.win32: \
    ${fea_org.eclipse.e4.rcp_4.35.0.v20250228-0640_PLATFORM_win32.win32.x86-64}

# Blacklist OSGi enroute compile-only bundles so the resolver is forced to use
# the actual Eclipse Platform runtime bundles for OSGi service packages.
-runblacklist.enroute: \
    osgi.identity;filter:='(osgi.identity=osgi.cmpn)',\
    osgi.identity;filter:='(osgi.identity=osgi.enterprise)',\
    osgi.identity;filter:='(osgi.identity=osgi.annotation)'

# SWTBot requirements - click "Resolve" in bndtools to add resolved versions to -runbundles.
# Note: org.eclipse.swtbot.eclipse.finder is intentionally omitted — it pulls in
# Eclipse IDE / p2 infrastructure which depends on Bouncy Castle multi-release JARs
# whose bnd.synthetic EE constraints (e.g. !(version>=21.0.0)) cannot be satisfied
# on JavaSE-21.  The basic SWTBot from swt.finder is sufficient for all interactions
# used in SamplePartSWTBotTest.
-runrequires.swtbot: \
    osgi.identity;filter:='(osgi.identity=org.eclipse.swtbot.swt.finder)',\
    osgi.identity;filter:='(osgi.identity=org.eclipse.swtbot.junit4_x)',\
    osgi.identity;filter:='(&(osgi.identity=example.rcp.app.ui.swtbot.tests)(version>=0.1.0))'

# All application bundles (copied from app.ui_win32.win32.x86-64.bndrun, already resolved).
# After clicking "Resolve", bndtools will append the SWTBot bundles at the end.
-runbundles: \
	bndtools.runtime.applaunch.eclipse4;version='[0.1.0,0.1.1)',\
	com.sun.jna;version='[5.16.0,5.16.1)',\
	com.sun.jna.platform;version='[5.16.0,5.16.1)',\
	example.rcp.app.ui;version=snapshot,\
	example.rcp.app.ui.swtbot.tests;version=snapshot,\
	jakarta.annotation-api;version='[1.3.5,1.3.6)',\
	jakarta.annotation-api;version='[2.1.1,2.1.2)',\
	jakarta.inject.jakarta.inject-api;version='[1.0.5,1.0.6)',\
	jakarta.inject.jakarta.inject-api;version='[2.0.1,2.0.2)',\
	org.apache.aries.spifly.dynamic.bundle;version='[1.3.7,1.3.8)',\
	org.apache.batik.constants;version='[1.18.0,1.18.1)',\
	org.apache.batik.css;version='[1.18.0,1.18.1)',\
	org.apache.batik.i18n;version='[1.18.0,1.18.1)',\
	org.apache.batik.util;version='[1.18.0,1.18.1)',\
	org.apache.commons.commons-logging;version='[1.3.5,1.3.6)',\
	org.apache.commons.io;version='[2.6.0,2.6.1)',\
	org.apache.felix.gogo.command;version='[1.1.2,1.1.3)',\
	org.apache.felix.gogo.runtime;version='[1.1.6,1.1.7)',\
	org.apache.felix.gogo.shell;version='[1.1.4,1.1.5)',\
	org.apache.felix.scr;version='[2.2.12,2.2.13)',\
	org.apache.xmlgraphics;version='[2.10.0,2.10.1)',\
	org.eclipse.core.commands;version='[3.12.300,3.12.301)',\
	org.eclipse.core.contenttype;version='[3.9.600,3.9.601)',\
	org.eclipse.core.databinding;version='[1.13.400,1.13.401)',\
	org.eclipse.core.databinding.beans;version='[1.10.300,1.10.301)',\
	org.eclipse.core.databinding.observable;version='[1.13.300,1.13.301)',\
	org.eclipse.core.databinding.property;version='[1.10.300,1.10.301)',\
